# ============================================================
# .gitattributes - Chuẩn hóa line endings cho dự án Android
# Đảm bảo nhất quán giữa Windows (CRLF) và Linux/Mac (LF)
# ============================================================

# Mặc định: tất cả text file dùng LF trong repo,
# Git tự chuyển CRLF khi checkout trên Windows
* text=auto eol=lf

# ============================================================
# Source code - luôn LF
# ============================================================
*.java        text eol=lf
*.kt          text eol=lf
*.kts         text eol=lf
*.xml         text eol=lf
*.json        text eol=lf
*.md          text eol=lf
*.txt         text eol=lf
*.toml        text eol=lf
*.properties  text eol=lf
*.pro         text eol=lf
*.gradle      text eol=lf

# ============================================================
# Shell scripts - bắt buộc LF (chạy trên Linux/Mac)
# ============================================================
*.sh          text eol=lf
gradlew       text eol=lf

# ============================================================
# Batch scripts Windows - bắt buộc CRLF
# ============================================================
*.bat         text eol=crlf
*.cmd         text eol=crlf
gradlew.bat   text eol=crlf

# ============================================================
# Binary files - không xử lý line endings
# ============================================================
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.webp        binary
*.ico         binary
*.svg         binary
*.jks         binary
*.keystore    binary
*.jar         binary
*.aar         binary
*.apk         binary
*.aab         binary
*.so          binary
*.class       binary
*.zip         binary
