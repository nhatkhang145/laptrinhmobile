<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Avatar Container -->
        <FrameLayout
            android:id="@+id/avatarContainer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/ivAvatar"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/logo"
                android:background="@drawable/bg_avatar_circle"
                app:shapeAppearanceOverlay="@style/CircleImage" />

            <!-- Online/Offline Dot -->
            <View
                android:id="@+id/viewStatusDot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_gravity="bottom|end"
                android:layout_margin="2dp"
                android:background="@drawable/bg_online_dot"
                android:elevation="2dp" />
        </FrameLayout>

        <!-- Info Section -->
        <LinearLayout
            android:id="@+id/infoLayout"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/actionLayout"
            app:layout_constraintStart_toEndOf="@id/avatarContainer"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nguyễn Văn A"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:ignore="HardcodedText" />

            <TextView
                android:id="@+id/tvContact"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="090 123 4567"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                tools:ignore="HardcodedText" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Tag Role -->
                <TextView
                    android:id="@+id/tvRoleTag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@color/danger_text"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="2dp"
                    android:text="ADMIN"
                    android:textColor="@color/white"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    tools:ignore="HardcodedText" />

                <!-- Status Detail -->
                <TextView
                    android:id="@+id/tvStatusDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="@string/status_online"
                    android:textColor="@color/status_online"
                    android:textSize="11sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Icons -->
        <LinearLayout
            android:id="@+id/actionLayout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/btnEdit"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                app:iiv_color="@color/text_secondary"
                app:iiv_icon="faw_pen"
                android:contentDescription="Sửa" />

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/btnLock"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                app:iiv_color="#EF4444"
                app:iiv_icon="faw_lock"
                android:contentDescription="Khóa" />

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/btnMore"
                android:layout_width="20dp"
                android:layout_height="20dp"
                app:iiv_color="@color/text_secondary"
                app:iiv_icon="faw_ellipsis_v"
                android:contentDescription="Xem thêm" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
