<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Left: tên món, số lượng, ghi chú -->
    <LinearLayout
        android:id="@+id/llLeft"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/tvSubTotal"
        android:layout_marginEnd="12dp"
        android:orientation="vertical">

        <!-- Số lượng x Tên món -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvQtyBadge"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:background="@drawable/bg_badge_dark"
                android:gravity="center"
                android:text="1"
                android:textColor="@color/surface"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvItemName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:fontFamily="sans-serif-medium"
                android:text="Tên món ăn"
                android:textColor="@color/text_primary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Đơn giá -->
        <TextView
            android:id="@+id/tvUnitPrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginStart="38dp"
            android:text="55.000đ / phần"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Ghi chú pill (ẩn khi không có ghi chú) -->
        <LinearLayout
            android:id="@+id/llNote"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginStart="38dp"
            android:background="@drawable/bg_note_pill"
            android:gravity="center_vertical"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:visibility="gone">

            <com.mikepenz.iconics.view.IconicsImageView
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginEnd="5dp"
                app:iiv_color="@color/text_secondary"
                app:iiv_icon="faw-align-left"
                app:iiv_size="10dp" />

            <TextView
                android:id="@+id/tvNote"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=""
                android:textColor="@color/text_secondary"
                android:textSize="11sp" />

        </LinearLayout>

    </LinearLayout>

    <!-- Right: thành tiền và nút Hủy -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:gravity="end">

        <TextView
            android:id="@+id/tvSubTotal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:text="55.000"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:background="@drawable/bg_badge_light"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:text="Hủy món"
            android:textColor="@color/danger"
            android:textSize="11sp"
            android:visibility="gone" />
    </LinearLayout>

</RelativeLayout>
