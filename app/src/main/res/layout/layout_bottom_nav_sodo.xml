<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bottomNav"
    android:layout_width="match_parent"
    android:layout_height="72dp"
    android:layout_gravity="bottom"
    android:background="@drawable/bg_bottom_nav"
    android:elevation="8dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <LinearLayout
        android:id="@+id/navOrder"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/navOrderPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="7dp"
            android:paddingEnd="18dp"
            android:paddingBottom="7dp">

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/navOrderIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Order"
                app:iiv_color="@color/nav_icon_inactive"
                app:iiv_icon="faw-clipboard-list"
                app:iiv_size="22dp" />

            <TextView
                android:id="@+id/navOrderText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_order"
                android:textColor="@color/nav_icon_inactive"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navSoDo"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/navSoDoPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_nav_active"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="7dp"
            android:paddingEnd="18dp"
            android:paddingBottom="7dp">

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/navSoDoIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="So do"
                app:iiv_color="@color/accent"
                app:iiv_icon="faw-th-large"
                app:iiv_size="22dp" />

            <TextView
                android:id="@+id/navSoDoText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_so_do"
                android:textColor="@color/accent"
                android:textSize="11sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/navTienIch"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:background="?attr/selectableItemBackground"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/navTienIchPill"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="7dp"
            android:paddingEnd="18dp"
            android:paddingBottom="7dp">

            <com.mikepenz.iconics.view.IconicsImageView
                android:id="@+id/navTienIchIcon"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="Tien ich"
                app:iiv_color="@color/nav_icon_inactive"
                app:iiv_icon="faw-cog"
                app:iiv_size="22dp" />

            <TextView
                android:id="@+id/navTienIchText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/nav_tien_ich"
                android:textColor="@color/nav_icon_inactive"
                android:textSize="11sp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
