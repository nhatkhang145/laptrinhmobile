<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface"
    android:fitsSystemWindows="true"
    tools:ignore="HardcodedText">

    <!-- ==================== TOP APP BAR (dark) ==================== -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_alignParentTop="true"
        android:background="#1A2B4A"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <!-- Back arrow -->
        <com.mikepenz.iconics.view.IconicsImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="8dp"
            app:iiv_color="@color/surface"
            app:iiv_icon="faw-arrow-left"
            app:iiv_size="20dp" />

        <!-- Title -->
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:fontFamily="sans-serif-medium"
            android:text="Lập Order - Bàn A01"
            android:textColor="@color/surface"
            android:textSize="17sp"
            android:textStyle="bold" />

        <!-- 3-dot menu -->
        <com.mikepenz.iconics.view.IconicsImageView
            android:id="@+id/btnMore"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            android:padding="10dp"
            app:iiv_color="@color/surface"
            app:iiv_icon="faw-ellipsis-v"
            app:iiv_size="20dp" />

    </LinearLayout>

    <!-- ==================== BOTTOM ACTION BAR ==================== -->
    <LinearLayout
        android:id="@+id/bottomBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:background="@color/surface"
        android:elevation="12dp"
        android:orientation="horizontal"
        android:padding="16dp">

        <!-- HỦY BỎ button -->
        <LinearLayout
            android:id="@+id/btnHuyBo"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_btn_secondary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:text="HỦY BỎ"
                android:textColor="@color/text_secondary"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- ĐỒNG Ý button -->
        <LinearLayout
            android:id="@+id/btnDongY"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:background="@drawable/bg_btn_primary"
            android:clickable="true"
            android:focusable="true"
            android:gravity="center"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                android:text="ĐỒNG Ý"
                android:textColor="@color/surface"
                android:textSize="15sp"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- ==================== SCROLLABLE CONTENT ==================== -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/bottomBarLayout"
        android:layout_below="@id/headerLayout"
        android:background="#F8FAFC"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Search bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:layout_marginStart="16dp"
                android:layout_marginTop="12dp"
                android:layout_marginEnd="16dp"
                android:background="@drawable/bg_search_bar"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="12dp"
                android:paddingEnd="12dp">

                <com.mikepenz.iconics.view.IconicsImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_marginEnd="8dp"
                    app:iiv_color="@color/text_hint"
                    app:iiv_icon="faw-search"
                    app:iiv_size="16dp" />

                <EditText
                    android:id="@+id/etSearch"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:background="@null"
                    android:hint="Nhập tên món cần tìm"
                    android:textColorHint="@color/text_hint"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:inputType="textVisiblePassword"
                    android:imeOptions="actionSearch"
                    android:singleLine="true" />

            </LinearLayout>

            <!-- Category Tabs -->
            <com.google.android.material.tabs.TabLayout
                android:id="@+id/tabLayoutCategories"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                app:tabMode="scrollable"
                app:tabIndicatorHeight="36dp"
                app:tabIndicator="@drawable/bg_tab_active_dark"
                app:tabIndicatorGravity="center"
                app:tabIndicatorFullWidth="true"
                app:tabPaddingStart="20dp"
                app:tabPaddingEnd="20dp"
                app:tabIndicatorAnimationMode="elastic"
                app:tabRippleColor="@null"
                app:tabGravity="start"
                app:tabSelectedTextColor="@color/surface"
                app:tabTextColor="@color/text_primary"
                android:background="@color/surface" />

            <!-- ===== MENU ITEM LIST ===== -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMenuItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingBottom="20dp"
                android:clipToPadding="false"
                tools:listitem="@layout/item_menu_lap_order" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</RelativeLayout>
